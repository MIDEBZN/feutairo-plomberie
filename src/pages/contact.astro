---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Feutairo" description="Contactez Feutairo pour toute urgence ou demande de devis en plomberie à Bruxelles.">
  <div class="page-header section text-center">
    <div class="container">
      <h1 class="text-gradient">Nous Contacter</h1>
      <p class="subtitle">Notre équipe est à votre disposition 24h/24 et 7j/7 pour toute urgence ou demande de devis.</p>
    </div>
  </div>

  <section class="section pt-0">
    <div class="container">
      <div class="contact-wrapper">
        <div class="contact-info animate-fade-in">
          <div class="glass info-card">
            <h3>Urgence Plomberie ?</h3>
            <p>N'attendez pas que les dégâts s'aggravent. Appelez-nous directement !</p>
            <a href="tel:+3221234567" class="btn btn-primary emergency-btn">
              <span class="icon">📞</span> +32 2 123 45 67
            </a>
          </div>

          <div class="details-list">
            <div class="detail-item glass">
              <div class="icon">📍</div>
              <div>
                <h4>Adresse</h4>
                <p>1000 Bruxelles, Belgique</p>
              </div>
            </div>
            <div class="detail-item glass">
              <div class="icon">✉️</div>
              <div>
                <h4>Email</h4>
                <p>info@feutairo.be</p>
              </div>
            </div>
            <div class="detail-item glass">
              <div class="icon">🕒</div>
              <div>
                <h4>Horaires</h4>
                <p>Lundi - Dimanche : 24h/24</p>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-form-container glass animate-fade-in delay-200">
          <h3>Demander un Devis</h3>
          <form class="contact-form" onsubmit="event.preventDefault(); alert('Message envoyé avec succès !');">
            <div class="form-group">
              <label for="name">Nom complet</label>
              <input type="text" id="name" placeholder="Votre nom" required />
            </div>
            <div class="form-group">
              <label for="phone">Téléphone</label>
              <input type="tel" id="phone" placeholder="Votre numéro" required />
            </div>
            <div class="form-group">
              <label for="service">Service souhaité</label>
              <select id="service" required>
                <option value="" disabled selected>Choisissez un service</option>
                <option value="depannage">Dépannage d'urgence</option>
                <option value="installation">Installation</option>
                <option value="entretien">Entretien chaudière</option>
                <option value="autre">Autre</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" rows="4" placeholder="Décrivez votre problème ou projet..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full">Envoyer la demande</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: radial-gradient(circle at center, rgba(37,99,235,0.1) 0%, transparent 70%);
  }
  .subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }
  .pt-0 {
    padding-top: 0;
  }
  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .info-card {
    padding: 3rem;
    border-radius: 1.5rem;
    text-align: center;
    background: linear-gradient(135deg, rgba(37,99,235,0.1), rgba(15,23,42,0.6));
  }
  .info-card h3 {
    margin-bottom: 1rem;
  }
  .info-card p {
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
  .emergency-btn {
    font-size: 1.25rem;
    padding: 1rem 2rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .details-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .detail-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: 1rem;
  }
  .detail-item .icon {
    font-size: 1.5rem;
  }
  .detail-item h4 {
    margin-bottom: 0.25rem;
    font-size: 1rem;
  }
  .detail-item p {
    color: var(--text-muted);
    margin: 0;
  }

  .contact-form-container {
    padding: 3rem;
    border-radius: 1.5rem;
  }
  .contact-form-container h3 {
    margin-bottom: 2rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .form-group label {
    font-weight: 500;
    font-size: 0.95rem;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 1rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    color: var(--text-color);
    font-family: var(--font-body);
    transition: var(--transition);
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2);
  }
  .w-full {
    width: 100%;
  }

  @media (max-width: 968px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
    }
    .contact-form-container {
      padding: 2rem;
    }
  }
</style>
